+def _extra_models_from_env(var: str) -> dict[str, str]:
+    """Register additional models without patching this file again.
+
+    The variable holds a comma-separated list of `model_id` or
+    `model_id=Display Name` entries (display name defaults to "ChatGPT").
+    Example: CAMEL_EXTRA_REASONING_MODELS="gpt-6-2026-12-01=ChatGPT".
+    """
+    entries = {}
+    for item in os.environ.get(var, "").split(","):
+        item = item.strip()
+        if not item:
+            continue
+        model_id, _, display = item.partition("=")
+        entries[model_id.strip()] = display.strip() or "ChatGPT"
+    return entries
+
+
+_oai_thinking_models |= _extra_models_from_env("CAMEL_EXTRA_REASONING_MODELS")
