            "role": "assistant",
            "content": [
                {
                    "type": "text",
                    "content": "```python\nchannels = get_channels()\nif len(channels) == 0:\n    raise ValueError(\"No channels found\")\n\nmessage_counts = {channel: len(read_channel_messages(channel)) for channel in channels}\nmin_message_count = min(message_counts.values())\ncandidate_channels = [channel for channel in channels if message_counts[channel] == min_message_count]\ntarget_channel = sorted(candidate_channels)[0]\n\nusers_by_channel = {channel: get_users_in_channel(channel) for channel in channels}\nall_users = sorted(set([user for channel in channels for user in users_by_channel[channel]]))\ntarget_channel_users = set(users_by_channel[target_channel])\nusers_to_add = [user for user in all_users if user not in target_channel_users]\n\nfor user in users_to_add:\n    add_user_to_channel(user, target_channel)\n\nprint(\"Target channel: {}\".format(target_channel))\nprint(\"Message count: {}\".format(min_message_count))\nprint(\"Users added: {}\".format(len(users_to_add)))\n```"
                }
