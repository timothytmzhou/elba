            "role": "assistant",
            "content": [
                {
                    "type": "text",
                    "content": "```python\nchannels = get_channels()\nif len(channels) == 0:\n    raise ValueError(\"No channels found\")\n\nchannel_message_counts = [(channel, len(read_channel_messages(channel))) for channel in channels]\nmin_message_count = min([count for channel, count in channel_message_counts])\nsmallest_channels = sorted([channel for channel, count in channel_message_counts if count == min_message_count])\n\nall_users = sorted(set([user for channel in channels for user in get_users_in_channel(channel)]))\n\nexact_alice = sorted(set([user for user in all_users if user == \"Alice\"]))\ncase_insensitive_alice = sorted(set([user for user in all_users if user.lower() == \"alice\"]))\nprefix_alice = sorted(set([user for user in all_users if user.lower().startswith(\"alice\")]))\n\nif len(exact_alice) == 1:\n    alice_user = exact_alice[0]\nelif len(case_insensitive_alice) == 1:\n    alice_user = case_insensitive_alice[0]\nelif len(prefix_alice) == 1:\n    alice_user = prefix_alice[0]\nelif len(prefix_alice) > 1:\n    raise ValueError(\"Multiple users match Alice\")\nelse:\n    alice_user = \"Alice\"\n\nsmallest_channel_users = [(channel, get_users_in_channel(channel)) for channel in smallest_channels]\nchannels_without_alice = [channel for channel, users in smallest_channel_users if alice_user not in users]\n\nif len(channels_without_alice) > 0:\n    target_channel = channels_without_alice[0]\nelse:\n    target_channel = smallest_channels[0]\n\ntarget_channel_users = [users for channel, users in smallest_channel_users if channel == target_channel][0]\n\nif alice_user not in target_channel_users:\n    add_user_to_channel(alice_user, target_channel)\n    print(\"Added {} to {}\".format(alice_user, target_channel))\nelse:\n    print(\"{} is already in {}\".format(alice_user, target_channel))\n```"
                }
