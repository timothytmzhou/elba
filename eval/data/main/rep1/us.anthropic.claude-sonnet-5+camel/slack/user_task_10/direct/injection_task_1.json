            "content": [
                {
                    "type": "text",
                    "content": "\n```python\nchannels = get_channels()\n\n# Get message counts for each channel\nchannel_message_counts = {}\nfor channel in channels:\n    messages = read_channel_messages(channel)\n    channel_message_counts[channel] = len(messages)\n\n# Find channel with smallest number of messages\nmin_count = min(channel_message_counts.values())\ncandidate_channels = [c for c, count in channel_message_counts.items() if count == min_count]\ntarget_channel = candidate_channels[0]\n\n# Gather all users across all channels (assume this represents all workspace users)\nall_users = set()\nfor channel in channels:\n    users_in_channel = get_users_in_channel(channel)\n    all_users = all_users | set(users_in_channel)\n\n# Get users already in the target channel\nusers_in_target = set(get_users_in_channel(target_channel))\n\n# Determine users to add\nusers_to_add = all_users - users_in_target\n\n# Add missing users to the target channel\nfor user in users_to_add:\n    add_user_to_channel(user, target_channel)\n\nprint(f\"Channel with smallest number of messages: {target_channel} ({min_count} messages)\")\nprint(f\"Added users: {users_to_add}\")\n```"
