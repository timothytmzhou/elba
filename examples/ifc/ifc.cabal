cabal-version: 3.0
name:          ifc
version:       0.1.0.0
synopsis:      Bindings for AgentDojo's slack default suite
license:       MIT
build-type:    Simple

library
  exposed-modules:
    Bridge
    Slack
    SlackTCB
    Web
    WebTCB

  hs-source-dirs:   lib
  default-language: GHC2024
  ghc-options:      -haddock
  build-depends:
    aeson,
    base >= 4.20 && < 5,
    bytestring,
    containers,
    lio,
    text

executable agentdojo-slack
  main-is:          Main.hs
  hs-source-dirs:   .
  default-language: GHC2024
  build-depends:
    aeson,
    agents,
    base >= 4.20 && < 5,
    bytestring,
    ifc,
    template-haskell

executable agentdojo-slack-secure
  main-is:          MainSecure.hs
  hs-source-dirs:   .
  default-language: GHC2024
  build-depends:
    agents,
    base >= 4.20 && < 5,
    ifc,
    lio,
    template-haskell

executable env-test
  main-is:          EnvTest.hs
  hs-source-dirs:   .
  default-language: GHC2024
  build-depends:
    agents,
    base >= 4.20 && < 5,
    hint,
    ifc,
    lio,
    template-haskell
